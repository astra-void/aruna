{
  "name": "aruna-workspace",
  "private": true,
  "scripts": {
    "build:native": "pnpm --filter @arunajs/compiler build:native",
    "build": "pnpm build:native && turbo run build",
    "check": "pnpm build:native && turbo run check",
    "test": "pnpm build:native && turbo run test",
    "lint": "pnpm build:native && turbo run lint",
    "typecheck": "pnpm build:native && turbo run typecheck",
    "aruna": "pnpm --filter aruna aruna"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "commander": "^12.1.0",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.1.1",
    "tsx": "^4.21.0",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.2"
}
