{
  "name": "aruna",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aruna": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@arunajs/compiler": "workspace:*",
    "@arunajs/core": "workspace:*",
    "commander": "^12.1.0",
    "gradient-string": "^2.0.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "pnpm typecheck",
    "aruna": "node ./dist/cli.js"
  }
}
