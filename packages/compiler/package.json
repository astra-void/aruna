{
  "name": "@arunajs/compiler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@arunajs/core": "workspace:*",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build:native": "tsx scripts/build-native-target.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:release": "vitest run test/build-native-target.test.ts test/native-build.test.ts test/native-loader.test.ts test/native-staging.test.ts test/release.test.ts",
    "lint": "pnpm typecheck"
  }
}
